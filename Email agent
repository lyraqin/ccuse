# 五、MCP Server（Python版）

创建 `mcp_server.py`

```python
from fastapi import FastAPI
import requests
import datetime
import os
from dotenv import load_dotenv

load_dotenv()

app = FastAPI()

# ========== Gmail ==========
def get_gmail_headers():
    return {
        "Authorization": f"Bearer {os.getenv('GOOGLE_REFRESH_TOKEN')}"
    }

@app.get("/gmail/unread")
def gmail_unread():
    url = "https://gmail.googleapis.com/gmail/v1/users/me/messages?q=is:unread"
    res = requests.get(url, headers=get_gmail_headers()).json()

    emails = []
    for m in res.get("messages", [])[:5]:
        emails.append({"id": m["id"]})

    return emails


# ========== Google Calendar ==========
@app.get("/calendar/today")
def today_events():
    today = datetime.datetime.utcnow().isoformat() + "Z"
    url = f"https://www.googleapis.com/calendar/v3/calendars/primary/events?timeMin={today}"

    res = requests.get(url, headers=get_gmail_headers()).json()

    events = []
    for e in res.get("items", []):
        events.append({
            "title": e["summary"],
            "time": e["start"].get("dateTime", "")
        })

    return events


# ========== Outlook ==========
@app.get("/outlook/emails")
def outlook_emails():
    url = "https://graph.microsoft.com/v1.0/me/messages?$top=5"
    headers = {
        "Authorization": f"Bearer {os.getenv('MS_REFRESH_TOKEN')}"
    }

    res = requests.get(url, headers=headers).json()

    emails = []
    for m in res.get("value", []):
        emails.append({
            "subject": m["subject"],
            "from": m["from"]["emailAddress"]["address"]
        })

    return emails
```

启动：

```bash
uvicorn mcp_server:app --reload --port 3000
```

