# 六、每日总结脚本（核心）

创建 `daily_summary.py`

```python
import requests
import os
from anthropic import Anthropic
import smtplib
from email.mime.text import MIMEText
from dotenv import load_dotenv

load_dotenv()

# 1️⃣ 拉数据
events = requests.get("http://localhost:3000/calendar/today").json()
gmail = requests.get("http://localhost:3000/gmail/unread").json()
outlook = requests.get("http://localhost:3000/outlook/emails").json()

raw = f"""
日历：
{events}

Gmail未读：
{gmail}

Outlook邮件：
{outlook}
"""

# 2️⃣ Claude总结
client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

resp = client.messages.create(
    model="claude-3-5-sonnet",
    max_tokens=500,
    messages=[{
        "role": "user",
        "content": f"整理成简洁高效的每日摘要：\n{raw}"
    }]
)

summary = resp.content[0].text

# 3️⃣ 发邮件
msg = MIMEText(summary)
msg["Subject"] = "📅 每日摘要"
msg["From"] = os.getenv("SMTP_EMAIL")
msg["To"] = os.getenv("SMTP_EMAIL")

with smtplib.SMTP_SSL("smtp.gmail.com", 465) as server:
    server.login(os.getenv("SMTP_EMAIL"), os.getenv("SMTP_PASSWORD"))
    server.send_message(msg)

print("✅ 已发送")
```

